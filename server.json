{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.terranode-co/mcp-server-terranode",
  "title": "Terranode Geospatial API",
  "description": "Point-in-polygon, nearest feature, spatial join, and distance tools for US geospatial datasets",
  "version": "0.1.9",
  "websiteUrl": "https://docs.terranode.co/integrations/mcp/",
  "repository": {
    "url": "https://github.com/terranode-co/mcp-server-terranode",
    "source": "github",
    "id": "1193773082"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@terranode-co/mcp-server",
      "version": "0.1.9",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TERRANODE_API_KEY",
          "description": "API key from app.terranode.co",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "TERRANODE_API_URL",
          "description": "API base URL (defaults to https://api.terranode.co)",
          "isRequired": false,
          "isSecret": false,
          "default": "https://api.terranode.co"
        }
      ]
    }
  ]
}
